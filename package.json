{
  "name": "fullstack-technical-test-cloud",
  "version": "1.0.0",
  "description": "AWS Serverless Report Processing Service — Event-driven: API Gateway → SQS → Lambda → SES",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0"
  },
  "devDependencies": {
    "jest": "^30.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "semi": true
  }
}
